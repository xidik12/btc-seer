# BTC Oracle Configuration

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBAPP_URL=https://your-domain.com

# API Keys (optional — free tier endpoints work without keys for most)
CRYPTOPANIC_API_KEY=your_cryptopanic_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=btc-oracle/1.0

# Database
DATABASE_URL=sqlite:///./btc_oracle.db

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ML
MODEL_DIR=app/models/weights
PREDICTION_INTERVAL_MINUTES=60

# Binance (no key needed for public endpoints)
BINANCE_BASE_URL=https://api.binance.com
