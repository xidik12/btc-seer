# BTC Oracle Configuration

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBAPP_URL=https://your-domain.com

# API Keys (optional — free tier endpoints work without keys for most)
CRYPTOPANIC_API_KEY=your_cryptopanic_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=btc-oracle/1.0

# Database
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./btc_oracle.db
# Production (PostgreSQL — Railway auto-sets this via PG plugin):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Backups (enabled by default, runs every 6h)
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_HOURS=6
# BACKUP_DIR=/data/backups
# BACKUP_RETENTION_DAYS=7
# BACKUP_SQLITE_SNAPSHOT=true

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ML
MODEL_DIR=app/models/weights
PREDICTION_INTERVAL_MINUTES=60

# Multi-coin expansion APIs (optional — collectors gracefully skip if empty)
ETHERSCAN_API_KEY=your_etherscan_key
SOLSCAN_API_KEY=your_solscan_key

# Binance (no key needed for public endpoints)
BINANCE_BASE_URL=https://api.binance.com
